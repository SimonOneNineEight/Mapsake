# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Web Push / VAPID keys (Story 5.1+). Generate with: npx web-push generate-vapid-keys
# The PUBLIC key is exposed to the client (push subscription); the PRIVATE key is SERVER-ONLY
# and is used by the Story 5-3 cron sender to sign pushes — never expose it to the client.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
